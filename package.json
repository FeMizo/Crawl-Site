{
  "name": "seo-crawler",
  "version": "2.13.26",
  "private": true,
  "description": "SEO Crawler con interfaz web y reporte Excel",
  "scripts": {
    "predev": "node scripts/clean-next-dist.js development",
    "dev": "next dev --port 3666",
    "prebuild": "node scripts/clean-next-dist.js production",
    "build": "next build",
    "start": "next start",
    "postinstall": "node scripts/prisma-generate-safe.js",
    "db:up": "docker compose up -d",
    "db:push": "prisma db push",
    "db:restore-local": "powershell -ExecutionPolicy Bypass -File scripts/restore-local-db.ps1 -SkipGenerate",
    "db:seed": "prisma db seed",
    "prisma:generate": "node scripts/prisma-generate-safe.js",
    "roles:promote": "node scripts/promote-user-role.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/react": "19.2.14",
    "jest": "^29.7.0",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
