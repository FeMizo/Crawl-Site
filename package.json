{
  "name": "seo-crawler",
  "version": "2.4.0",
  "description": "SEO Crawler con interfaz web y reporte Excel",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cross-env PORT=3001 nodemon src/server.js",
    "dev:web": "next dev -p 3000",
    "db:up": "docker compose up -d",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "build": "next build",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:api": "cross-env PORT=3001 node src/server.js",
    "start:web": "next start -p 3000"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^6.5.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
