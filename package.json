{
  "name": "seo-crawler",
  "version": "2.10.0",
  "description": "SEO Crawler con interfaz web y reporte Excel",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cross-env PORT=3001 nodemon src/server.js",
    "dev:web": "next dev -p 3000",
    "db:up": "docker compose up -d",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "prisma:generate": "prisma generate",
    "build": "next build",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:api": "cross-env PORT=3001 node src/server.js",
    "start:web": "next start -p 3000"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cross-env": "^7.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "test": "jest --runInBand"
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "cors": "^2.8.5",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "19.2.14",
    "nodemon": "^3.0.2",
    "prisma": "^6.19.2",
    "typescript": "5.9.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
    "jest": "^29.7.0",
    "supertest": "^6.4.0",
  "engines": {
    "node": ">=18.17.0"
  }
}
