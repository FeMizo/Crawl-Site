# Prisma / Neon
dashboard_DATABASE_URL="postgresql://user:password@host-pooler.region.neon.tech/dbname?channel_binding=require&sslmode=require"
dashboard_DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.neon.tech/dbname?sslmode=require"

# App
JWT_SECRET="replace-with-a-long-random-secret"
APP_URL="http://localhost:3000"
ROADMAP_ADMIN_EMAILS="admin@example.com"

# Optional server settings
CORS_ORIGIN="http://localhost:3000"
CRAWL_MAX_PER_MIN="2"

# Optional Next build setting
NEXT_DIST_DIR=".next"
