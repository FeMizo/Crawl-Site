generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("dashboard_DATABASE_URL")
  directUrl = env("dashboard_DATABASE_URL_UNPOOLED")
}

enum UserRole {
  OWNER
  SUPER_ADMIN
  ADMIN
  EDITOR
  USER
}

enum CrawlStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum PlanType {
  FREE
  BASIC
  STARTER
  PRO
  AGENCY
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  role         UserRole      @default(USER)
  phoneCountry String?
  phoneNumber  String?
  passwordHash String
  emailVerified       Boolean             @default(false)
  projects            Project[]
  crawlRuns           CrawlRun[]
  subscription        Subscription?
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             PlanType  @default(FREE)
  stripeCustomerId String?
  stripeSubId      String?
  maxProjects      Int       @default(1)
  maxPagesPerCrawl Int       @default(50)
  maxCrawlsPerMonth Int      @default(2)
  maxHistoryRuns   Int       @default(1)
  features         String[]  @default([])
  projectsCreated  Int       @default(0)
  trialEndsAt      DateTime?
  expiresAt        DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([stripeSubId])
  @@index([stripeCustomerId])
}

model Project {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  targetUrl String
  crawlRuns CrawlRun[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, createdAt])
}

model CrawlRun {
  id           String              @id @default(cuid())
  userId       String
  projectId    String
  sourceUrl    String
  sourceType   String              @default("crawl")
  maxPages     Int
  rateDelay    Int
  checkExt     Boolean
  total        Int                 @default(0)
  withIssues   Int                 @default(0)
  stats        Json?
  downloadName String?
  status       CrawlStatus         @default(COMPLETED)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storedPages  CrawlRunPage[]
  storedDups   CrawlRunDuplicate[]

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model CrawlRunPage {
  id          String   @id @default(cuid())
  runId       String
  position    Int
  url         String
  finalUrl    String?
  statusCode  Int?
  hasIssues   Boolean  @default(false)
  title       String?
  titleLen    Int      @default(0)
  description String?
  descLen     Int      @default(0)
  payload     Json
  createdAt   DateTime @default(now())
  run         CrawlRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, position])
  @@index([runId, hasIssues, position])
  @@index([url])
}

model CrawlRunDuplicate {
  id        String   @id @default(cuid())
  runId     String
  position  Int
  title     String
  urlCount  Int      @default(0)
  payload   Json
  createdAt DateTime @default(now())
  run       CrawlRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, position])
  @@index([runId, urlCount])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RoadmapPhase {
  id          String        @id @default(cuid())
  title       String
  description String?
  position    Int           @default(0)
  tasks       RoadmapTask[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([position])
}

model RoadmapTask {
  id        String       @id @default(cuid())
  phaseId   String
  title     String
  completed Boolean      @default(false)
  position  Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  phase     RoadmapPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId, position])
}
