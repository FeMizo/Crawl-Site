generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  passwordHash String
  projects     Project[]
  crawlRuns    CrawlRun[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Project {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  targetUrl  String
  crawlRuns  CrawlRun[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CrawlRun {
  id           String   @id @default(cuid())
  userId       String
  projectId    String
  sourceUrl    String
  source       String
  maxPages     Int
  rateDelay    Int
  checkExt     Boolean
  total        Int      @default(0)
  withIssues   Int      @default(0)
  stats        Json?
  duplicates   Json?
  pages        Json?
  downloadName String?
  status       String   @default("completed")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}
